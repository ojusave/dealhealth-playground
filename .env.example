# DealHealth Playground — environment variables (set on Render Dashboard)

# dealhealth-api (web service)
EXECUTION_MODE=workflows
MODEL_REFRESH_MINUTES=15
RENDER_API_KEY=
WORKFLOW_TASK_SLUG=dealhealth-workflows/analyzeOpportunity
EVENTS_SECRET=
ALLOWED_ORIGIN=
API_BASE_URL=
# OpenAI + Anthropic keys live in the Render env group `dealhealth-shared`.
# Link that group to dealhealth-api and dealhealth-workflows in the Dashboard.
# Optional: XAI_API_KEY on the service if you want Grok models.
XAI_API_KEY=
EVENTS_SECRET=
API_BASE_URL=

# dealhealth-web (static site — build-time)
VITE_API_BASE_URL=
