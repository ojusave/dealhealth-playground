OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# dealhealth-workflows (workflow service — create manually)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
EVENTS_SECRET=
API_BASE_URL=

# dealhealth-web (static site — build-time)
VITE_API_BASE_URL=
